# Copy to .env.local and fill in real values. Never commit .env.local.

# ── Database (PHP bridge) ───────────────────────────────────────────
# MySQL :3306 is firewalled; all DB access goes through the PHP bridge.
BRIDGE_URL=
BRIDGE_SECRET=
# Pre-alert receipt upload endpoint (route falls back to BRIDGE_URL if unset).
PREALERT_UPLOAD_URL=

# ── Session ─────────────────────────────────────────────────────────
SESSION_SECRET=

# ── SMTP (cPanel mailbox — password-reset email) ────────────────────
# Visible From: is noreply@ but the envelope MAIL FROM is SMTP_USER (info@)
# so cPanel sender-verify passes. Port 465 = implicit TLS; 587 = STARTTLS.
SMTP_HOST=mail.swiftboxtt.com
SMTP_PORT=465
SMTP_USER=info@swiftboxtt.com
SMTP_PASS=
SMTP_FROM="Swift Box <noreply@swiftboxtt.com>"

# Base URL used to build password-reset links.
APP_URL=http://localhost:3005
